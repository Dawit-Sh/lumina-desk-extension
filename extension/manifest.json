{
  "manifest_version": 3,
  "name": "Lumina",
  "version": "1.0.0",
  "description": "AI-powered writing tools — grammar, paraphrasing, summarization, and more on every page.",
  "permissions": ["contextMenus", "storage", "activeTab"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Lumina",
    "default_icon": {
      "32": "icons/icon32.png",
      "64": "icons/icon64.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": {
    "32": "icons/icon32.png",
    "64": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "lumina@lumina-extension",
      "strict_min_version": "109.0"
    }
  }
}
